       <property name="styleSheet">
        <string notr="true">#labelTime, #labelSpeed, #labelAccuracy {
    background-color: #ffffff;
    border: 1px solid #e0e0e0;
    border-radius: 4px;
    padding: 8px 15px;
    font-size: 14px;
    font-weight: bold;
    color: #333333;
    margin: 5px;
}

#labelTime {
    border-left: 3px solid #4a90e2;
}

#labelSpeed {
    border-left: 3px solid #27ae60;
}

#labelAccuracy {
    border-left: 3px solid #e67e22;
}

#textDisplay {
    background-color: #ffffff;
    border: 2px solid #e0e0e0;
    border-radius: 6px;
    padding: 15px;
    font-family: 'Courier New', monospace;
    font-size: 18px;
    line-height: 1.6;
    selection-background-color: #d4e6f1;
}

#virtualKeyboard {
    background-color: #f0f0f0;
    border: 1px solid #cccccc;
    border-radius: 8px;
    padding: 10px;
}

#virtualKeyboard QPushButton {
    background-color: #ffffff;
    border: 1px solid #bdbdbd;
    border-radius: 4px;
    padding: 8px;
    font-size: 14px;
    font-weight: bold;
    color: #333333;
    min-width: 40px;
    min-height: 40px;
}

#virtualKeyboard QPushButton:hover {
    background-color: #e0e0e0;
    border-color: #999999;
}

#virtualKeyboard QPushButton:pressed {
    background-color: #4a90e2;
    color: #ffffff;
    border-color: #357abd;
}

#btn_tab, #btn_caps, #btn_shift_left, #btn_shift_right, 
#btn_ctrl_left, #btn_ctrl_right {
    background-color: #e0e0e0;
    font-size: 12px;
}

#btn_space {
    min-width: 200px;
    background-color: #e8e8e8;
}

#btn_enter {
    background-color: #27ae60;
    color: white;
}

#btn_enter:hover {
    background-color: #219a52;
}

#btn_backspace {
    background-color: #e67e22;
    color: white;
}

#btn_backspace:hover {
    background-color: #d35400;
}

#virtualKeyboard QPushButton[active=&quot;true&quot;] {
    background-color: #f1c40f;
    color: #333333;
    border: 2px solid #e67e22;
}</string>
