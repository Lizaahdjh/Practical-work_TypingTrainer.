       <property name="styleSheet">
        <string notr="true">#pageResults  #label_2, #label_4,  #label_6{
    font-size: 24px;
    font-weight: bold;
    padding: 20px;
}

#pageResults QGroupBox {
    background-color: #ffffff;
    border: 2px solid #e0e0e0;
    border-radius: 8px;
    margin-top: 10px;
    padding-top: 20px;
    font-size: 16px;
    font-weight: bold;
}

#pageResults QGroupBox::title {
    subcontrol-origin: margin;
    left: 20px;
    padding: 0 10px 0 10px;
    background-color: #ffffff;
}

#pageResults QLabel {
    font-size: 16px;
    padding: 8px;
}

#resultTime, #resultSpeed, #resultAccuracy {
    font-size: 20px;
    font-weight: bold;
    color: #4a90e2;
}

#btnRestartTraining, #btnReturnToMain {
    background-color: #4a90e2;
    color: #ffffff;
    border: none;
    border-radius: 4px;
    padding: 12px 24px;
    font-size: 14px;
    font-weight: bold;
    min-width: 150px;
}

#btnRestartTraining:hover, #btnReturnToMain:hover {
    background-color: #357abd;
}

#btnRestartTraining:pressed, #btnReturnToMain:pressed {
    background-color: #2a5f9e;
}

#btnReturnToMain {
    background-color: #95a5a6;
}

#btnReturnToMain:hover {
    background-color: #7f8c8d;
}

#label {
    font-size: 30px;
    font-weight: bold;
    color: #2c3e50;
    background-color: transparent;
    padding: 15px;
    qproperty-alignment: AlignCenter;
    border-bottom: 4px solid #e74c3c;
    margin: 10px;
}</string>
